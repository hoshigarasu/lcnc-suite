#!/usr/bin/env bash
# LinuxCNC DISPLAY launcher for lcnc-suite
# Usage: lcnc-suite -ini /path/to/machine.ini
#   or:  [DISPLAY] DISPLAY = lcnc-suite   in your INI file
set -euo pipefail

# Resolve real path (follows symlinks so PATH/symlink installs work)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
GATEWAY_DIR="$SCRIPT_DIR/lcnc-gateway"
WEBUI_DIR="$SCRIPT_DIR/lcnc-webui"
DIST_DIR="$WEBUI_DIR/dist"

# ── Parse -ini argument (LinuxCNC passes: lcnc-suite -ini /path/to.ini) ──
INI_FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -ini) INI_FILE="$2"; shift 2 ;;
    *)    shift ;;
  esac
done

# ── Read optional config from INI [DISPLAY] section ──
ini_get() {
  # Returns value or empty string if not found.
  # inivar returns the rest of the line verbatim, so inline "# comment"
  # text leaks into the value — strip it and trim surrounding whitespace.
  local v
  v="$(inivar -ini "$INI_FILE" -sec DISPLAY -var "$1" 2>/dev/null || true)"
  v="${v%%#*}"
  v="${v#"${v%%[![:space:]]*}"}"
  v="${v%"${v##*[![:space:]]}"}"
  printf '%s' "$v"
}

if [[ -n "$INI_FILE" ]]; then
  HOST="${LCNC_WEBUI_HOST:-$(ini_get WEBUI_HOST)}"
  PORT="${LCNC_WEBUI_PORT:-$(ini_get WEBUI_PORT)}"
  BROWSER="${LCNC_WEBUI_BROWSER:-$(ini_get WEBUI_BROWSER)}"
  DEV="${LCNC_WEBUI_DEV:-$(ini_get WEBUI_DEV)}"
  CAM_SOURCE="${LCNC_CAMERA_SOURCE:-$(ini_get CAMERA_SOURCE)}"
  CAM_RES="${LCNC_CAMERA_RESOLUTION:-$(ini_get CAMERA_RESOLUTION)}"
  CAM_FPS="${LCNC_CAMERA_FPS:-$(ini_get CAMERA_FPS)}"
  WIRE_FORMAT="${WEBUI_WIRE_FORMAT:-$(ini_get WEBUI_WIRE_FORMAT)}"
  STATUS_DELTA="${WEBUI_STATUS_DELTA:-$(ini_get WEBUI_STATUS_DELTA)}"
  UVLOOP_ON="${WEBUI_UVLOOP:-$(ini_get WEBUI_UVLOOP)}"
  ADAPTIVE_POLL="${WEBUI_ADAPTIVE_POLL:-$(ini_get WEBUI_ADAPTIVE_POLL)}"
  IDLE_POLL_HZ="${WEBUI_IDLE_POLL_HZ:-$(ini_get WEBUI_IDLE_POLL_HZ)}"
else
  HOST="${LCNC_WEBUI_HOST:-}"
  PORT="${LCNC_WEBUI_PORT:-}"
  BROWSER="${LCNC_WEBUI_BROWSER:-}"
  DEV="${LCNC_WEBUI_DEV:-}"
  CAM_SOURCE="${LCNC_CAMERA_SOURCE:-}"
  CAM_RES="${LCNC_CAMERA_RESOLUTION:-}"
  CAM_FPS="${LCNC_CAMERA_FPS:-}"
  WIRE_FORMAT="${WEBUI_WIRE_FORMAT:-}"
  STATUS_DELTA="${WEBUI_STATUS_DELTA:-}"
  UVLOOP_ON="${WEBUI_UVLOOP:-}"
  ADAPTIVE_POLL="${WEBUI_ADAPTIVE_POLL:-}"
  IDLE_POLL_HZ="${WEBUI_IDLE_POLL_HZ:-}"
fi

# Apply defaults
HOST="${HOST:-0.0.0.0}"
PORT="${PORT:-8000}"
BROWSER="${BROWSER:-1}"
DEV="${DEV:-0}"

VITE_PORT="5173"

# Pass INI path if available
[[ -n "$INI_FILE" ]] && export LCNC_INI_FILE="$INI_FILE"

# Camera (optional — empty means disabled)
[[ -n "$CAM_SOURCE" ]] && export LCNC_CAMERA_SOURCE="$CAM_SOURCE"
[[ -n "$CAM_RES" ]] && export LCNC_CAMERA_RESOLUTION="$CAM_RES"
[[ -n "$CAM_FPS" ]] && export LCNC_CAMERA_FPS="$CAM_FPS"

# Perf experiment flags (all optional — unset = default OFF)
[[ -n "$WIRE_FORMAT"   ]] && export WEBUI_WIRE_FORMAT="$WIRE_FORMAT"
[[ -n "$STATUS_DELTA"  ]] && export WEBUI_STATUS_DELTA="$STATUS_DELTA"
[[ -n "$UVLOOP_ON"     ]] && export WEBUI_UVLOOP="$UVLOOP_ON"
[[ -n "$ADAPTIVE_POLL" ]] && export WEBUI_ADAPTIVE_POLL="$ADAPTIVE_POLL"
[[ -n "$IDLE_POLL_HZ"  ]] && export WEBUI_IDLE_POLL_HZ="$IDLE_POLL_HZ"

# ── Ensure NVM Node is on PATH (LinuxCNC may launch with minimal PATH) ──
if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  source "$HOME/.nvm/nvm.sh"
fi

# ── Activate Python venv ──
source "$GATEWAY_DIR/.venv/bin/activate"

# ── Log gateway stdout/stderr to /tmp so we can read it after the fact
# without needing the launching terminal. `tee` runs in a process
# substitution so normal terminal output is preserved.
LCNC_LOG="/tmp/lcnc-gateway.log"
: > "$LCNC_LOG"  # truncate on each start
exec > >(tee -a "$LCNC_LOG") 2>&1

# ── uvicorn loop selection (Experiment 3: uvloop opt-in) ──
# Force --loop asyncio unless WEBUI_UVLOOP=1, so A/B comparisons aren't
# muddied by uvicorn auto-detecting uvloop on hosts that happen to have it
# installed. When the flag is on, uvloop is explicitly selected.
if [[ "${UVLOOP_ON:-}" == "1" ]]; then
  UVICORN_LOOP=(--loop uvloop)
else
  UVICORN_LOOP=(--loop asyncio)
fi

# ── Dev mode: Vite hot-reload + gateway ──
if [[ "$DEV" == "1" ]]; then
  echo "lcnc-suite: DEV mode — Vite on :$VITE_PORT, gateway on :$PORT"

  VITE_PGID=""

  cleanup() {
    # Kill Vite's entire process group (npm → node tree)
    [[ -n "$VITE_PGID" ]] && kill -TERM -- -"$VITE_PGID" 2>/dev/null || true
    wait 2>/dev/null || true
  }
  trap cleanup EXIT INT TERM

  # Start Vite in its own session so we can kill the whole process tree
  setsid bash -c "cd '$WEBUI_DIR' && exec npm run dev -- --host '$HOST' --port '$VITE_PORT' --strictPort" &
  VITE_PGID=$!

  # Open browser to Vite port
  if [[ "$BROWSER" == "1" ]]; then
    ( sleep 2 && xdg-open "http://localhost:$VITE_PORT" 2>/dev/null ) &
  fi

  # Run gateway in foreground (no DIST_DIR — Vite serves frontend)
  python3 -m uvicorn gateway:app --host "$HOST" --port "$PORT" --app-dir "$GATEWAY_DIR" "${UVICORN_LOOP[@]}"
  exit $?
fi

# ── Production mode: gateway serves built frontend ──
if [[ ! -f "$DIST_DIR/index.html" ]]; then
  echo "ERROR: Built frontend not found at $DIST_DIR" >&2
  echo "Run:  cd $WEBUI_DIR && npm run build" >&2
  exit 1
fi

export LCNC_WEBUI_DIST_DIR="$DIST_DIR"

if [[ "$BROWSER" == "1" ]]; then
  ( sleep 1.5 && xdg-open "http://localhost:$PORT" 2>/dev/null ) &
fi

echo "lcnc-suite: serving on http://$HOST:$PORT"

# exec replaces shell — signals go directly to uvicorn for clean shutdown
exec python3 -m uvicorn gateway:app --host "$HOST" --port "$PORT" --app-dir "$GATEWAY_DIR" "${UVICORN_LOOP[@]}"
