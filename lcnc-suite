#!/usr/bin/env bash
# LinuxCNC DISPLAY launcher for lcnc-suite
# Usage: lcnc-suite -ini /path/to/machine.ini
#   or:  [DISPLAY] DISPLAY = lcnc-suite   in your INI file
set -euo pipefail

# Resolve real path (follows symlinks so PATH/symlink installs work)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
GATEWAY_DIR="$SCRIPT_DIR/lcnc-gateway"
WEBUI_DIR="$SCRIPT_DIR/lcnc-webui"
DIST_DIR="$WEBUI_DIR/dist"

# ── Parse -ini argument (LinuxCNC passes: lcnc-suite -ini /path/to.ini) ──
INI_FILE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -ini) INI_FILE="$2"; shift 2 ;;
    *)    shift ;;
  esac
done

# ── Read optional config from INI [DISPLAY] section ──
ini_get() {
  # Returns value or empty string if not found.
  # inivar returns the rest of the line verbatim, so inline "# comment"
  # text leaks into the value — strip it and trim surrounding whitespace.
  local v
  v="$(inivar -ini "$INI_FILE" -sec DISPLAY -var "$1" 2>/dev/null || true)"
  v="${v%%#*}"
  v="${v#"${v%%[![:space:]]*}"}"
  v="${v%"${v##*[![:space:]]}"}"
  printf '%s' "$v"
}

if [[ -n "$INI_FILE" ]]; then
  HOST="${LCNC_WEBUI_HOST:-$(ini_get WEBUI_HOST)}"
  PORT="${LCNC_WEBUI_PORT:-$(ini_get WEBUI_PORT)}"
  BROWSER="${LCNC_WEBUI_BROWSER:-$(ini_get WEBUI_BROWSER)}"
  DEV="${LCNC_WEBUI_DEV:-$(ini_get WEBUI_DEV)}"
  CAM_SOURCE="${LCNC_CAMERA_SOURCE:-$(ini_get CAMERA_SOURCE)}"
  CAM_RES="${LCNC_CAMERA_RESOLUTION:-$(ini_get CAMERA_RESOLUTION)}"
  CAM_FPS="${LCNC_CAMERA_FPS:-$(ini_get CAMERA_FPS)}"
  WIRE_FORMAT="${WEBUI_WIRE_FORMAT:-$(ini_get WEBUI_WIRE_FORMAT)}"
  STATUS_DELTA="${WEBUI_STATUS_DELTA:-$(ini_get WEBUI_STATUS_DELTA)}"
  UVLOOP_ON="${WEBUI_UVLOOP:-$(ini_get WEBUI_UVLOOP)}"
  ADAPTIVE_POLL="${WEBUI_ADAPTIVE_POLL:-$(ini_get WEBUI_ADAPTIVE_POLL)}"
  IDLE_POLL_HZ="${WEBUI_IDLE_POLL_HZ:-$(ini_get WEBUI_IDLE_POLL_HZ)}"
else
  HOST="${LCNC_WEBUI_HOST:-}"
  PORT="${LCNC_WEBUI_PORT:-}"
  BROWSER="${LCNC_WEBUI_BROWSER:-}"
  DEV="${LCNC_WEBUI_DEV:-}"
  CAM_SOURCE="${LCNC_CAMERA_SOURCE:-}"
  CAM_RES="${LCNC_CAMERA_RESOLUTION:-}"
  CAM_FPS="${LCNC_CAMERA_FPS:-}"
  WIRE_FORMAT="${WEBUI_WIRE_FORMAT:-}"
  STATUS_DELTA="${WEBUI_STATUS_DELTA:-}"
  UVLOOP_ON="${WEBUI_UVLOOP:-}"
  ADAPTIVE_POLL="${WEBUI_ADAPTIVE_POLL:-}"
  IDLE_POLL_HZ="${WEBUI_IDLE_POLL_HZ:-}"
fi

# Apply defaults
HOST="${HOST:-0.0.0.0}"
PORT="${PORT:-8000}"
BROWSER="${BROWSER:-1}"
DEV="${DEV:-0}"

VITE_PORT="5173"

# Pass INI path if available
[[ -n "$INI_FILE" ]] && export LCNC_INI_FILE="$INI_FILE"

# Camera (optional — empty means disabled)
[[ -n "$CAM_SOURCE" ]] && export LCNC_CAMERA_SOURCE="$CAM_SOURCE"
[[ -n "$CAM_RES" ]] && export LCNC_CAMERA_RESOLUTION="$CAM_RES"
[[ -n "$CAM_FPS" ]] && export LCNC_CAMERA_FPS="$CAM_FPS"

# Perf experiment flags (all optional — unset = default OFF)
[[ -n "$WIRE_FORMAT"   ]] && export WEBUI_WIRE_FORMAT="$WIRE_FORMAT"
[[ -n "$STATUS_DELTA"  ]] && export WEBUI_STATUS_DELTA="$STATUS_DELTA"
[[ -n "$UVLOOP_ON"     ]] && export WEBUI_UVLOOP="$UVLOOP_ON"
[[ -n "$ADAPTIVE_POLL" ]] && export WEBUI_ADAPTIVE_POLL="$ADAPTIVE_POLL"
[[ -n "$IDLE_POLL_HZ"  ]] && export WEBUI_IDLE_POLL_HZ="$IDLE_POLL_HZ"

# ── Ensure NVM Node is on PATH (LinuxCNC may launch with minimal PATH) ──
if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  source "$HOME/.nvm/nvm.sh"
fi

# ── Activate Python venv ──
source "$GATEWAY_DIR/.venv/bin/activate"

# ── Diagnostic launcher log — bypasses the tee pipe entirely so we
# can see what the launcher is doing even if tee blocks. Append-per-
# call (no exec >FD redirect) so each line hits disk via its own
# open/write/close — no stdio buffer that could be lost on SIGKILL.
LCNC_LAUNCHER_LOG="/tmp/lcnc-launcher.log"
: > "$LCNC_LAUNCHER_LOG"
_log() { printf '[%s] %s\n' "$(date +%H:%M:%S.%3N)" "$*" >> "$LCNC_LAUNCHER_LOG"; }
_log "launcher start pid=$$"

# ── Log gateway stdout/stderr to /tmp so we can read it after the fact
# without needing the launching terminal. Two independent isolations:
#
#   1. setsid → tee gets its own session, so terminal Ctrl-C SIGINT
#      cannot reach it directly. (GNU tee has no SIGINT handler — default
#      disposition would kill it on the spot, dropping any in-flight
#      gateway shutdown output.)
#
#   2. ( … & ) double-fork → tee is reparented to PID 1 immediately, so
#      it is NOT a child of the launcher bash. This matters at script
#      exit: bash 5.2 sits in wait4(-1) waiting for every direct child
#      to be reaped; with tee as a direct child, bash would block until
#      tee got EOF, but tee can't get EOF until bash closes FDs 1+2,
#      which only happens after wait4 returns — classic deadlock that
#      prevents LinuxCNC's Cleanup phase from running.
#
# Named FIFO (not >(setsid tee …)) because process substitution leaves
# a hidden FD inside bash that defeats the reparent-to-PID-1 trick.
LCNC_LOG="/tmp/lcnc-gateway.log"
[[ -f "$LCNC_LOG" ]] && mv "$LCNC_LOG" "${LCNC_LOG}.prev"
: > "$LCNC_LOG"
LCNC_FIFO="$(mktemp -u /tmp/lcnc-fifo.XXXXXX)"
mkfifo -m 600 "$LCNC_FIFO"
( setsid tee -a "$LCNC_LOG" < "$LCNC_FIFO" & )
exec > "$LCNC_FIFO" 2>&1
_log "tee started via FIFO=$LCNC_FIFO (setsid + reparented to init)"
# Clean the FIFO file on exit. Tee already opened the read end before
# unlink, so unlink doesn't disturb tee — it exits naturally on EOF.
# Capture $? FIRST — must be the very first thing in the trap, before
# any command that would clobber it. rc<128 = explicit exit; rc>=128
# = killed by signal (rc-128 = signal number).
trap '_EXIT_RC=$?; rm -f "$LCNC_FIFO" 2>/dev/null; _log "EXIT trap fired rc=$_EXIT_RC"' EXIT

# ── uvicorn loop selection (Experiment 3: uvloop opt-in) ──
# Force --loop asyncio unless WEBUI_UVLOOP=1, so A/B comparisons aren't
# muddied by uvicorn auto-detecting uvloop on hosts that happen to have it
# installed. When the flag is on, uvloop is explicitly selected.
if [[ "${UVLOOP_ON:-}" == "1" ]]; then
  UVICORN_LOOP=(--loop uvloop)
else
  UVICORN_LOOP=(--loop asyncio)
fi

# Force colored output even though stdout is piped through tee above —
# uvicorn/Click auto-disable ANSI codes on non-TTY, which swallows the
# INFO/URL highlighting in the launching terminal.
UVICORN_COLOR=(--use-colors)

# Bound HTTP-response drain on shutdown. uvicorn's default (None) waits
# indefinitely for in-flight responses to finish; with LAN browsers
# fetching multi-MB STLs over /assets/, that meant 8–66 s shutdowns
# (uvicorn HttpToolsProtocol.shutdown only sets keep_alive=False for
# in-flight cycles, never aborts the transport — drain is bounded by
# either response completion or kernel tcp_retries2). Desktop CNC
# control is a singleton process, not a rolling-deploy server: the
# correct policy on SIGTERM is "stop now, in-flight downloads error
# out." 1 s is enough for the shutdown log line to flush, short
# enough to feel instant. Validated against probe data 2026-05-01.
UVICORN_GRACEFUL=(--timeout-graceful-shutdown 1)

# Bounded SIGTERM→SIGKILL escalation. The gateway's clean shutdown path
# (uvicorn graceful drain + FastAPI lifespan teardown) only works while
# the asyncio event loop is responsive. Under stuck-peer scenarios (LAN
# browser holding HTTP keep-alive open, transport.close() deferred on a
# non-empty write buffer) the loop can stall for 40 s, during which
# --timeout-graceful-shutdown 1 cannot fire (its timer needs a healthy
# loop). The kernel does not have that problem.
#
# Pattern: SIGTERM, poll up to 2 s for exit, SIGKILL if still alive.
# Belt + suspenders: --timeout-graceful-shutdown gives clean lifespan
# logs in the 99 % case; this kill is the load-bearing backstop.
#
# Why SIGKILL is acceptable: the HAL safety layer (oneshot.0.out →
# webui-safety.trip-latch) latches ESTOP within 500 ms of gateway
# silence regardless of how the gateway died. Lifespan teardown is
# nice-to-have for log cleanliness, not a safety requirement. The
# cooperative SIGTERM in hal_reader / hal_watchdog / compensation
# means the HAL components shut down cleanly even when the gateway
# is killed mid-flight.
_wait_or_kill() {
    local pid="$1" tag="$2"
    local i
    for i in {1..20}; do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then
        _log "$tag _term: gateway pid=$pid did not exit in 2s, SIGKILL"
        kill -KILL "$pid" 2>/dev/null
    fi
    wait "$pid" 2>/dev/null || true
}

# === TEMP HAL-SAMPLE PROBE === capture every servo-cycle value of the
# safety-chain bool pins. The HAL sampler component fills a FIFO every
# servo cycle (~1ms); halsampler -n 0 drains it to stdout. We pipe into
# a CSV so we can correlate Python-side heartbeat events with what the
# realtime thread actually sees on oneshot.0.in / oneshot.0.out. The
# matching `loadrt sampler` lives in the LinuxCNC HAL config file
# (lcnc_webui.hal). If halsampler isn't on PATH (older LinuxCNC, or
# packaging miss), we skip silently — gateway operation is unaffected.
SAMPLER_PID=""
HAL_SAMPLE_PATH="/tmp/lcnc-hal-sample.csv"

_start_hal_sampler() {
    local mode="$1"
    if ! command -v halsampler >/dev/null 2>&1; then
        _log "$mode halsampler not on PATH — skipping HAL-sample capture"
        return
    fi
    # Self-describing CSV: write a header so the bundler / human readers
    # know the column layout. halsampler appends raw rows after this.
    # Columns mirror sampler cfg in lcnc_webui.hal (cfg=bbbbbbf).
    printf '# t_sample,heartbeat,hb_ok,connected,trip_latch,motion_enabled,paused,vel\n' \
        > "$HAL_SAMPLE_PATH"
    # `stdbuf -oL` forces line-buffered stdout so the file fills as
    # samples arrive, not in 8 KB chunks. Without it the redirect
    # default (fully buffered) leaves the file empty for many seconds.
    # `-t` prefixes each line with the sample number (servo-cycle id)
    # so we can detect missed cycles by gaps in the sequence — that's
    # the diagnostic we actually need (gateway-side logs already show
    # message timing). No `-n` means continuous capture (a previous
    # version mistakenly used `-n 0` which means "read 0 then exit").
    # halsampler exits when its sampler component is unloaded (LinuxCNC
    # shutdown), so no explicit kill is strictly required; we still send
    # SIGTERM in the trap to flush stdout promptly.
    stdbuf -oL halsampler -t >> "$HAL_SAMPLE_PATH" 2>>"$LCNC_LAUNCHER_LOG" &
    SAMPLER_PID=$!
    _log "$mode halsampler started pid=$SAMPLER_PID → $HAL_SAMPLE_PATH"
    # Detect early exit (e.g. sampler component not loaded — HAL config
    # change wasn't picked up because LinuxCNC wasn't fully restarted).
    sleep 0.2
    if ! kill -0 "$SAMPLER_PID" 2>/dev/null; then
        _log "$mode halsampler exited within 200ms — sampler not loaded? Check HAL config."
        SAMPLER_PID=""
    fi
}

_stop_hal_sampler() {
    if [[ -n "$SAMPLER_PID" ]]; then
        # `|| true` because halsampler may have already exited (e.g. if
        # the sampler component was unloaded by LinuxCNC shutdown before
        # we get here). With set -e a failed kill would otherwise abort
        # the trap and leave us with rc=1.
        kill -TERM "$SAMPLER_PID" 2>/dev/null || true
        _log "halsampler SIGTERM → pid=$SAMPLER_PID"
        SAMPLER_PID=""
    fi
}

# === TEMP PROC-STATUS PROBE === sample /proc/<gateway_pid>/status every 1s
# and append a structured event to /tmp/lcnc-trace.log so the bundler can
# correlate gateway memory / context-switch counts against [LAG] events.
# Cheap (~50us per sample) and runs in a separate bash subshell so a hang
# in the proc read can't block our trap path.
PROC_STATUS_PID=""

_start_proc_status_loop() {
    local gw_pid="$1"
    local mode="$2"
    if [[ -z "$gw_pid" ]]; then return; fi
    (
        # Run until the gateway exits OR we get SIGTERM.
        trap 'exit 0' TERM INT
        while kill -0 "$gw_pid" 2>/dev/null; do
            if [[ -r "/proc/$gw_pid/status" ]]; then
                local rss="0" thr="0" vol="0" nvol="0"
                while IFS= read -r line; do
                    case "$line" in
                        VmRSS:*)             rss=$(echo "$line"          | awk '{print $2}') ;;
                        Threads:*)           thr=$(echo "$line"          | awk '{print $2}') ;;
                        voluntary_ctxt*)     vol=$(echo "$line"          | awk '{print $2}') ;;
                        nonvoluntary_ctxt*)  nvol=$(echo "$line"         | awk '{print $2}') ;;
                    esac
                done < "/proc/$gw_pid/status"
                # NDJSON line — same schema as gateway/hal_reader emit.
                # Atomic O_APPEND under PIPE_BUF (4 KB) so this can't tear.
                local now_ns
                now_ns=$(date +%s%N)
                printf '{"t_wall_ns":%s,"t_mono_ms":0,"proc":"launcher","pid":%s,"tag":"proc.status","level":"info","gw_pid":%s,"vm_rss_kb":%s,"threads":%s,"voluntary_ctxt":%s,"nonvoluntary_ctxt":%s}\n' \
                    "$now_ns" "$$" "$gw_pid" "$rss" "$thr" "$vol" "$nvol" \
                    >> /tmp/lcnc-trace.log 2>/dev/null || true
            fi
            sleep 1
        done
    ) &
    PROC_STATUS_PID=$!
    _log "$mode proc.status loop started pid=$PROC_STATUS_PID (watching gw_pid=$gw_pid)"
}

_stop_proc_status_loop() {
    if [[ -n "$PROC_STATUS_PID" ]]; then
        kill -TERM "$PROC_STATUS_PID" 2>/dev/null || true
        PROC_STATUS_PID=""
    fi
}

# ── Dev mode: Vite hot-reload + gateway ──
if [[ "$DEV" == "1" ]]; then
  echo "lcnc-suite: DEV mode — Vite on :$VITE_PORT, gateway on :$PORT"

  # Trap mirrors production's canonical pattern. Bound only to INT/TERM
  # (not EXIT) so the gateway's exit status propagates instead of being
  # clobbered by an EXIT-trap-driven `exit 0`. The trap forwards exactly
  # one SIGTERM, then waits for the gateway's lifespan to finish before
  # exiting — so [SHUTDOWN] output is fully drained to the log.
  # Re-entrancy guard: ignore the same signal while the trap is running.
  # Without this, a second Ctrl-C re-enters _term while the first is
  # blocked in `wait`, corrupts bash's variable stack
  # (pop_var_context errors), and produces broken state.
  VITE_PGID=""
  GATEWAY_PID=""
  _term() {
    trap '' INT TERM
    _log "DEV _term: signal received"
    if [[ -n "$GATEWAY_PID" ]]; then
      _log "DEV _term: SIGTERM → gateway pid=$GATEWAY_PID"
      kill -TERM "$GATEWAY_PID" 2>/dev/null
    fi
    if [[ -n "$VITE_PGID" ]]; then
      _log "DEV _term: SIGTERM → vite pgid=$VITE_PGID"
      kill -TERM -- -"$VITE_PGID" 2>/dev/null
    fi
    _log "DEV _term: waiting for gateway pid=$GATEWAY_PID (≤2s, then SIGKILL)"
    _wait_or_kill "$GATEWAY_PID" "DEV"
    _stop_hal_sampler
    _stop_proc_status_loop
    _log "DEV _term: gateway reaped, exit 0"
    exit 0
  }
  trap _term INT TERM

  # Vite in its own session — kill the whole npm→node tree on shutdown.
  # FORCE_COLOR=1 keeps chalk's ANSI output alive through the tee pipe above
  # (otherwise Vite detects non-TTY and prints its banner plain).
  setsid bash -c "cd '$WEBUI_DIR' && FORCE_COLOR=1 exec npm run dev -- --host '$HOST' --port '$VITE_PORT' --strictPort" &
  VITE_PGID=$!
  _log "DEV vite started pgid=$VITE_PGID"

  # Open browser to Vite port
  if [[ "$BROWSER" == "1" ]]; then
    ( sleep 2 && xdg-open "http://localhost:$VITE_PORT" 2>/dev/null ) &
  fi

  # Gateway in its own session — terminal Ctrl-C cannot reach it; only
  # the trap above can signal it. Gateway exit (clean or crash) propagates:
  # we kill Vite, wait for reaping, and exit with the gateway's status.
  # No respawn — crash is operator-diagnosable, not silently retried.
  setsid python3 -m uvicorn gateway:app --host "$HOST" --port "$PORT" --app-dir "$GATEWAY_DIR" "${UVICORN_LOOP[@]}" "${UVICORN_COLOR[@]}" "${UVICORN_GRACEFUL[@]}" &
  GATEWAY_PID=$!
  _log "DEV gateway started pid=$GATEWAY_PID"
  _start_hal_sampler "DEV"
  _start_proc_status_loop "$GATEWAY_PID" "DEV"
  # `|| status=$?` keeps set -e from killing us when the gateway exits
  # non-zero (e.g. status=143 after SIGTERM). We need to propagate the
  # status to LinuxCNC's Cleanup via `exit "$status"` below.
  status=0
  wait "$GATEWAY_PID" || status=$?
  _log "DEV main wait returned status=$status"

  if [[ -n "$VITE_PGID" ]]; then
    _log "DEV main: SIGTERM → vite pgid=$VITE_PGID"
    kill -TERM -- -"$VITE_PGID" 2>/dev/null
  fi
  _log "DEV main: exit $status (vite orphaned, init reaps)"
  exit "$status"
fi

# ── Production mode: gateway serves built frontend ──
if [[ ! -f "$DIST_DIR/index.html" ]]; then
  echo "ERROR: Built frontend not found at $DIST_DIR" >&2
  echo "Run:  cd $WEBUI_DIR && npm run build" >&2
  exit 1
fi

export LCNC_WEBUI_DIST_DIR="$DIST_DIR"

if [[ "$BROWSER" == "1" ]]; then
  ( sleep 1.5 && xdg-open "http://localhost:$PORT" 2>/dev/null ) &
fi

# Print Vite-style banner so the operator sees the LAN URL too. ANSI
# escapes match Vite's chalk output (green ➜, bold label, cyan URL) so
# the production startup looks consistent with dev. When HOST=0.0.0.0
# (default), enumerate both loopback and the first non-loopback IPv4
# so a remote browser knows what to connect to. When HOST is an
# explicit IP, print just that.
_C_GREEN=$'\033[32m'; _C_BOLD=$'\033[1m'; _C_CYAN=$'\033[36m'; _C_RESET=$'\033[0m'
printf '\n  %slcnc-suite%s %sPROD%s mode\n\n' "$_C_GREEN$_C_BOLD" "$_C_RESET" "$_C_BOLD" "$_C_RESET"
if [[ "$HOST" == "0.0.0.0" ]]; then
  printf '  %s➜%s  %sLocal%s:   %shttp://localhost:%s/%s\n' \
    "$_C_GREEN" "$_C_RESET" "$_C_BOLD" "$_C_RESET" "$_C_CYAN" "$PORT" "$_C_RESET"
  _LAN_IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
  if [[ -n "$_LAN_IP" ]]; then
    printf '  %s➜%s  %sNetwork%s: %shttp://%s:%s/%s\n' \
      "$_C_GREEN" "$_C_RESET" "$_C_BOLD" "$_C_RESET" "$_C_CYAN" "$_LAN_IP" "$PORT" "$_C_RESET"
  fi
else
  printf '  %s➜%s  %shttp://%s:%s/%s\n' \
    "$_C_GREEN" "$_C_RESET" "$_C_CYAN" "$HOST" "$PORT" "$_C_RESET"
fi
echo

# Single signal authority: terminal signals reach the launcher only;
# the trap is the only path that signals the gateway. Trap forwards
# exactly one SIGTERM, then waits for the gateway's lifespan to finish
# before exiting — so [SHUTDOWN] output is fully drained to the log.
GATEWAY_PID=""
_term() {
  trap '' INT TERM
  _log "PROD _term: signal received"
  if [[ -n "$GATEWAY_PID" ]]; then
    _log "PROD _term: SIGTERM → gateway pid=$GATEWAY_PID"
    kill -TERM "$GATEWAY_PID" 2>/dev/null
  fi
  _log "PROD _term: waiting for gateway pid=$GATEWAY_PID (≤2s, then SIGKILL)"
  _wait_or_kill "$GATEWAY_PID" "PROD"
  _stop_hal_sampler
  _stop_proc_status_loop
  _log "PROD _term: gateway reaped, exit 0"
  exit 0
}
trap _term INT TERM

# setsid → uvicorn cannot be reached by terminal Ctrl-C; only the trap
# above can signal it. Gateway exit (clean or crash) propagates: when
# wait returns, the launcher exits with the gateway's status, which
# triggers LinuxCNC's Cleanup phase. No respawn — crash is operator-
# diagnosable, not silently retried.
setsid python3 -m uvicorn gateway:app --host "$HOST" --port "$PORT" --app-dir "$GATEWAY_DIR" "${UVICORN_LOOP[@]}" "${UVICORN_COLOR[@]}" "${UVICORN_GRACEFUL[@]}" &
GATEWAY_PID=$!
_log "PROD gateway started pid=$GATEWAY_PID"
_start_hal_sampler "PROD"
_start_proc_status_loop "$GATEWAY_PID" "PROD"
# `|| status=$?` keeps set -e from killing us when the gateway exits
# non-zero (e.g. status=143 after SIGTERM). We need to propagate the
# status to LinuxCNC's Cleanup via `exit "$status"` below.
status=0
wait "$GATEWAY_PID" || status=$?
_log "PROD main wait returned status=$status, exit $status"
exit "$status"
